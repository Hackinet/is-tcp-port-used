{
  "name": "is-tcp-port-used",
  "version": "1.0.1",
  "description": "Check if a TCP port is in use, wait until free or used. Zero dependencies, async/await, TypeScript.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tcp",
    "port",
    "check",
    "used",
    "free",
    "wait",
    "network",
    "socket",
    "is"
  ],
  "author": "Piyush Jha",
  "homepage": "https://github.com/Hackinet/is-tcp-port-used#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hackinet/is-tcp-port-used.git"
  },
  "bugs": {
    "url": "https://github.com/Hackinet/is-tcp-port-used/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
